PUBLIC_SUPABASE_URL=https://xxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...
PUBLIC_MAPTILER_KEY=your-maptiler-key
# Strava OAuth — public client ID is embedded in the redirect URL; the
# secret lives only in the backend Edge Function environment.
PUBLIC_STRAVA_CLIENT_ID=12345
STRAVA_CLIENT_ID=12345
STRAVA_CLIENT_SECRET=abc...
# RevenueCat web SDK public key (optional). When unset, the "Get Pro"
# CTA on /settings/upgrade falls back to a "coming soon" toast instead
# of opening a real checkout.
PUBLIC_REVENUECAT_WEB_API_KEY=
ANTHROPIC_API_KEY=sk-ant-...
# Set to 'true' in local dev to skip all subscription tier checks.
# Never set in production — the value is read at request time by gated
# server endpoints.
BYPASS_PAYWALL=false
