<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon. Wear OS reads this on API 26+ and applies its
  own circular mask in every launcher surface (Apps grid, Recents, watch
  face complications, tile picker). Without this file, Wear treats the
  legacy mipmap PNGs as different icon shapes per surface — that's why
  Recents was showing a rounded-square while Apps showed a circle.

  Foreground points back at the same PNG set we already ship; background
  fills with a coral matching the icon's dominant gradient colour, so any
  pixels beyond the PNG bounds (after masking) blend in instead of
  showing transparency.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background"/>
    <foreground android:drawable="@mipmap/ic_launcher_foreground"/>
</adaptive-icon>
