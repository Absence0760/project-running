<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext HTTP is only allowed for the Supabase dev loopback hosts. Real
  production URLs are HTTPS and go through the default (encrypted-only)
  base-config. Add more cleartext domains here for staging boxes on a LAN
  if you need to sideload-test the watch against them.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
