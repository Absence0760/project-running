# Copy this file to `.env.local` (gitignored) and flip flags as needed.
# Values are read at Gradle-configure time and emitted as BuildConfig
# constants. Changing .env.local requires a rebuild.

# Auto-sign-in with the seed dev user (`runner@test.com` / `testtest`) at
# app start instead of showing the sign-in screen. Only ever use this
# against a local / dev Supabase. Default false so release builds can't
# accidentally inherit dev creds.
BYPASS_LOGIN=false
# NOTE: This flag is only consulted on cold start when there is no cached
# session. A previously-signed-in user stays signed in across rebuilds
# because DataStore persists through `installDebug`. To get back to the
# sign-in screen, either tap the "Sign out" chip on the pre-run screen
# or wipe app data: `./gradlew uninstallDebug && ./gradlew installDebug`.

# Collect heart-rate samples from the Wear OS Health Services API and
# write avg_bpm into run.metadata. Default false because the Wear OS
# emulator synthesises HR samples that look like real readings — you do
# not want those ending up in production data. Flip to true when
# building for a real device with an HR sensor.
ENABLE_HR=false
