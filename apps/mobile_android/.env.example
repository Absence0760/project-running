SUPABASE_URL=http://10.0.2.2:54321
SUPABASE_ANON_KEY=your-supabase-anon-key
MAPTILER_KEY=your-maptiler-key
DEV_USER_EMAIL=
DEV_USER_PASSWORD=
# Set to 'true' in .env.local to skip all subscription tier checks.
# Lets you use Pro-gated features on the local Supabase without buying.
BYPASS_PAYWALL=false
# Base URL the "Share live link" action stitches the run id onto so the
# resulting `/live/{run_id}` URL points at the right spectator host.
# Defaults to the production host when unset.
WEB_BASE_URL=https://app.runapp.com
